# OpenRouter API Key (required)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (optional, defaults to anthropic/claude-opus-4.6)
# MODEL=anthropic/claude-opus-4.6

# Max context messages to keep in history (optional, default: 100)
# MAX_CONTEXT_MESSAGES=100

# Bash command timeout in ms (optional, default: 30000)
# BASH_TIMEOUT=30000
